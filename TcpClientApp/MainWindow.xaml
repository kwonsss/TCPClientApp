<Window x:Class="TcpServerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TcpServerApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid >
        <Grid.ColumnDefinitions >
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions >
        <Grid Grid.Column="0">
            <Grid.RowDefinitions >
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions >
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions >
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions >
                <Button Grid.Column="0" Width="80" Click="Connect_Click">Connect</Button>
                <Button Grid.Column="2" Width="80" Margin="8,0" Click="SendClear_Click">Clear</Button>
                <Button Grid.Column="3" Width="80" Click="SendButton_Click">Send</Button>
            </Grid>
            <TextBox Grid.Row="1" x:Name="InputTextBox" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
        </Grid>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions >
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions >
            <Button Grid.Row="0" Width="80" HorizontalAlignment="Right" Click="RevClear_Click">Clear</Button>
            <RichTextBox Grid.Row="1" x:Name="LogTextBox" />
        </Grid>

    </Grid>
</Window>
